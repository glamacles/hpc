# Copy to secret.auto.tfvars (gitignored) and paste your real token.
# Terraform auto-loads *.auto.tfvars on every apply, so the token persists across
# shells and runs — no need to re-export an env var each time.
#
#   cp secret.auto.tfvars.example secret.auto.tfvars
#   # then edit secret.auto.tfvars
#
# Keep a copy of the token in a password manager too — Cloudflare only shows it
# once, so if you lose it you'd have to roll the token.

cloudflare_api_token = "PASTE_YOUR_CLOUDFLARE_TOKEN_HERE"
